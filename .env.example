# =======================================
# OneClick-Host Environment Variables
# =======================================
# Copy this file to .env and fill in values

# ---------- PostgreSQL ----------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=oneclickhost
POSTGRES_USER=oneclick
POSTGRES_PASSWORD=change_me_in_production

# ---------- ASP.NET Core API ----------
ASPNETCORE_ENVIRONMENT=Development
CONNECTION_STRING=Host=db;Port=5432;Database=oneclickhost;Username=oneclick;Password=change_me_in_production
JWT_SECRET=super-secret-jwt-key-change-in-production-min-32-chars!!
JWT_ISSUER=oneclick-host
JWT_AUDIENCE=oneclick-host-client
JWT_EXPIRY_HOURS=24

# ---------- Python Worker ----------
WORKER_POLL_INTERVAL=5
WORKER_BUILD_TIMEOUT=900
DOCKER_HOST=unix:///var/run/docker.sock
WORKSPACE_DIR=/tmp/oneclick-workspace

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# ---------- Traefik ----------
TRAEFIK_DOMAIN=localhost

# OneClick-Host environment variables
# Copy this file to .env and fill in strong production values.

# PostgreSQL
POSTGRES_DB=oneclickhost
POSTGRES_USER=oneclick
POSTGRES_PASSWORD=replace-with-a-long-random-password

# ASP.NET Core API
ASPNETCORE_ENVIRONMENT=Production
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=oneclick-host
JWT_AUDIENCE=oneclick-host-client
JWT_EXPIRY_HOURS=24

# Python worker
WORKER_POLL_INTERVAL=5
WORKER_BUILD_TIMEOUT=900
MAX_CONCURRENT_BUILDS=1
WORKSPACE_DIR=/tmp/oneclick-workspace
CONTAINER_MEMORY_LIMIT=256m
CONTAINER_CPU_LIMIT=0.5
CONTAINER_PIDS_LIMIT=256

# Anti-abuse guardrails
MAX_ACTIVE_SERVICES_PER_USER=20
# Reserved for API rate limiting middleware; document and tune before opening access.
DEPLOYMENT_RATE_LIMIT_PER_MINUTE=10

# Frontend / routing
NEXT_PUBLIC_API_URL=/api
TRAEFIK_DOMAIN=localhost
